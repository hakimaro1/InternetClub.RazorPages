@page
@model InternetClub.RazorPages.Pages.Visits.IndexModel

@{
    var isRu = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ru";
    ViewData["Title"] = isRu ? "Посещения" : "Visits";
}

<h1>@(isRu ? "Посещения" : "Visits")</h1>

<p>
    <a asp-page="Create">@(isRu ? "Добавить" : "Create")</a>
</p>

<form class="row g-2 mb-3" method="get">
    <div class="col-sm-6 col-md-4">
        <input class="form-control" type="text" asp-for="Search" placeholder="@(isRu ? "Поиск (клиент/услуга/сотрудник)" : "Search (client/service/staff)")" />
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-primary" type="submit">@(isRu ? "Фильтр" : "Filter")</button>
        <a class="btn btn-outline-secondary" asp-page="./Index">@(isRu ? "Сброс" : "Reset")</a>
    </div>
</form>

<table class="table table-striped">
    <thead>
    <tr>
        <th>Id</th>
        <th>@(isRu ? "Клиент" : "Client")</th>
        <th>@(isRu ? "Услуга" : "Service")</th>
        <th>@(isRu ? "Сотрудник" : "Staff")</th>
        <th>@(isRu ? "Начало" : "Start")</th>
        <th>@(isRu ? "Длительность" : "Duration")</th>
        <th>@(isRu ? "Итого" : "Total")</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Visits)
    {
        <tr>
            <td>@item.Id</td>
            <td>@(item.Client == null ? "" : $"{item.Client.LastName} {item.Client.FirstName}")</td>
            <td>@item.Service?.Title</td>
            <td>@item.Stuff?.FullName</td>
            <td>@item.StartDateTime</td>
            <td>@item.Duration</td>
            <td>@item.TotalPrice</td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">@(isRu ? "Редактировать" : "Edit")</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">@(isRu ? "Подробнее" : "Details")</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">@(isRu ? "Удалить" : "Delete")</a>
            </td>
        </tr>
    }
    </tbody>
</table>

