@page
@model InternetClub.RazorPages.Pages.Reports.StuffStatsModel

@{
    var isRu = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ru";
    ViewData["Title"] = isRu ? "Статистика посещений по сотрудникам" : "Staff visit stats";
}

<h1>@(isRu ? "Статистика посещений по сотрудникам" : "Staff visit stats")</h1>

<table class="table table-striped">
    <thead>
    <tr>
        <th>@(isRu ? "Сотрудник" : "Staff")</th>
        <th>@(isRu ? "Количество посещений" : "Visits count")</th>
        <th>@(isRu ? "Выручка" : "Total revenue")</th>
        <th>@(isRu ? "Средняя длительность (мин)" : "Avg duration (min)")</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var row in Model.Rows)
    {
        <tr>
            <td>@row.StuffFullName</td>
            <td>@row.VisitsCount</td>
            <td>@row.TotalRevenue</td>
            <td>@row.AverageDurationMinutes</td>
        </tr>
    }
    </tbody>
</table>

