@page
@model InternetClub.RazorPages.Pages.Visits.DeleteModel

@{
    var isRu = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ru";
    ViewData["Title"] = isRu ? "Удаление посещения" : "Delete visit";
}

<h1>@(isRu ? "Удаление посещения" : "Delete visit")</h1>

<div class="alert alert-warning">
    @(isRu ? "Вы уверены, что хотите удалить это посещение?" : "Are you sure you want to delete this visit?")
</div>

<dl class="row">
    <dt class="col-sm-3">@(isRu ? "Клиент" : "Client")</dt>
    <dd class="col-sm-9">@($"{Model.Visit.Client?.LastName} {Model.Visit.Client?.FirstName}")</dd>
    <dt class="col-sm-3">@(isRu ? "Услуга" : "Service")</dt>
    <dd class="col-sm-9">@Model.Visit.Service?.Title</dd>
    <dt class="col-sm-3">@(isRu ? "Сотрудник" : "Staff")</dt>
    <dd class="col-sm-9">@Model.Visit.Stuff?.FullName</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Visit.Id" />
    <button type="submit" class="btn btn-danger">@(isRu ? "Удалить" : "Delete")</button>
    <a asp-page="./Index" class="btn btn-secondary">@(isRu ? "Отмена" : "Cancel")</a>
</form>

