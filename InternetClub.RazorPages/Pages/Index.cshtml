@page
@model IndexModel
@{
    var isRu = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ru";
    ViewData["Title"] = isRu ? "Главная" : "Home";
}

<div class="text-center">
    <h1 class="display-4">@(isRu ? "Добро пожаловать" : "Welcome")</h1>
    <p>@(isRu ? "Это приложение интернет‑клуба на ASP.NET Core Razor Pages." : "Internet club app built with ASP.NET Core Razor Pages.")</p>
</div>
