@page
@model InternetClub.RazorPages.Pages.Clients.CreateModel

@{
    var isRu = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ru";
    ViewData["Title"] = isRu ? "Добавление клиента" : "Create client";
}

<h1>@(isRu ? "Добавление клиента" : "Create client")</h1>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Client.LastName" class="form-label"></label>
                <input asp-for="Client.LastName" class="form-control" />
                <span asp-validation-for="Client.LastName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Client.FirstName" class="form-label"></label>
                <input asp-for="Client.FirstName" class="form-control" />
                <span asp-validation-for="Client.FirstName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Client.Phone" class="form-label"></label>
                <input asp-for="Client.Phone" class="form-control" />
                <span asp-validation-for="Client.Phone" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Client.Email" class="form-label"></label>
                <input asp-for="Client.Email" class="form-control" />
                <span asp-validation-for="Client.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Client.RegistrationDate" class="form-label"></label>
                <input asp-for="Client.RegistrationDate" class="form-control" type="date" asp-format="{0:yyyy-MM-dd}" />
                <span asp-validation-for="Client.RegistrationDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Client.Balance" class="form-label"></label>
                <input asp-for="Client.Balance" class="form-control" type="number" step="0.01" min="0" inputmode="decimal" />
                <span asp-validation-for="Client.Balance" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">@(isRu ? "Добавить" : "Create")</button>
            <a asp-page="Index" class="btn btn-secondary">@(isRu ? "Назад" : "Back")</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}