@page
@model InternetClub.RazorPages.Pages.Stuff.DetailsModel

@{
    var isRu = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ru";
    ViewData["Title"] = isRu ? "Детали сотрудника" : "Staff details";
}

<h1>@(isRu ? "Детали сотрудника" : "Staff details")</h1>

<dl class="row">
    <dt class="col-sm-3">@(isRu ? "ФИО" : "Full name")</dt>
    <dd class="col-sm-9">@Model.Stuff.FullName</dd>

    <dt class="col-sm-3">@(isRu ? "Табельный номер" : "Employee No.")</dt>
    <dd class="col-sm-9">@Model.Stuff.Enum</dd>
</dl>

<div class="mb-3">
    <a asp-page="./Edit" asp-route-id="@Model.Stuff.Id" class="btn btn-primary">@(isRu ? "Редактировать" : "Edit")</a>
    <a asp-page="./Index" class="btn btn-secondary">@(isRu ? "Назад" : "Back")</a>
</div>

