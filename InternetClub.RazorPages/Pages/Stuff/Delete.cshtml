@page
@model InternetClub.RazorPages.Pages.Stuff.DeleteModel

@{
    var isRu = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ru";
    ViewData["Title"] = isRu ? "Удаление сотрудника" : "Delete staff";
}

<h1>@(isRu ? "Удаление сотрудника" : "Delete staff")</h1>

<div class="alert alert-warning">
    @(isRu ? "Вы уверены, что хотите удалить этого сотрудника?" : "Are you sure you want to delete this staff member?")
</div>

<dl class="row">
    <dt class="col-sm-3">@(isRu ? "ФИО" : "Full name")</dt>
    <dd class="col-sm-9">@Model.Stuff.FullName</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Stuff.Id" />
    <button type="submit" class="btn btn-danger">@(isRu ? "Удалить" : "Delete")</button>
    <a asp-page="./Index" class="btn btn-secondary">@(isRu ? "Отмена" : "Cancel")</a>
</form>

