@page
@model InternetClub.RazorPages.Pages.Services.DeleteModel

@{
    var isRu = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ru";
    ViewData["Title"] = isRu ? "Удаление услуги" : "Delete service";
}

<h1>@(isRu ? "Удаление услуги" : "Delete service")</h1>

<div class="alert alert-warning">
    @(isRu ? "Вы уверены, что хотите удалить эту услугу?" : "Are you sure you want to delete this service?")
</div>

<dl class="row">
    <dt class="col-sm-3">@(isRu ? "Название" : "Title")</dt>
    <dd class="col-sm-9">@Model.Service.Title</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Service.Id" />
    <button type="submit" class="btn btn-danger">@(isRu ? "Удалить" : "Delete")</button>
    <a asp-page="./Index" class="btn btn-secondary">@(isRu ? "Отмена" : "Cancel")</a>
</form>

