@page
@model InternetClub.RazorPages.Pages.Stuff.DeleteModel

@{
    ViewData["Title"] = "Удаление сотрудника";
}

<h1>Удаление сотрудника</h1>

<div class="alert alert-warning">
    Вы уверены, что хотите удалить этого сотрудника?
</div>

<dl class="row">
    <dt class="col-sm-3">ФИО</dt>
    <dd class="col-sm-9">@Model.Stuff.FullName</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Stuff.Id" />
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a asp-page="./Index" class="btn btn-secondary">Отмена</a>
</form>

