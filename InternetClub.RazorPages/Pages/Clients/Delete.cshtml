@page
@model InternetClub.RazorPages.Pages.Clients.DeleteModel

@{
    var isRu = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ru";
    ViewData["Title"] = isRu ? "Удаление клиента" : "Delete client";
}

<h1>@(isRu ? "Удаление клиента" : "Delete client")</h1>

<div class="alert alert-warning">
    @(isRu ? "Вы уверены, что хотите удалить этого клиента?" : "Are you sure you want to delete this client?")
</div>

<dl class="row">
    <dt class="col-sm-3">@(isRu ? "Фамилия" : "Last name")</dt>
    <dd class="col-sm-9">@Model.Client.LastName</dd>
    <dt class="col-sm-3">@(isRu ? "Имя" : "First name")</dt>
    <dd class="col-sm-9">@Model.Client.FirstName</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Client.Id" />
    <button type="submit" class="btn btn-danger">@(isRu ? "Удалить" : "Delete")</button>
    <a asp-page="./Index" class="btn btn-secondary">@(isRu ? "Отмена" : "Cancel")</a>
</form>